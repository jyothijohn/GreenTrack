{
  "openapi": "3.0.3",
  "info": {
    "title": "GreenTrack ERP - Login API",
    "description": "OpenAPI specification for the GreenTrack Mobile Application authentication endpoint.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "Authenticate User",
        "description": "Authenticates an employee using their username and password and returns a JWT token along with the employee profile.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "thomasjohn@greencare.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Login successful."
                    },
                    "token": {
                      "type": "string",
                      "example": "mock-jwt-token-12345"
                    },
                    "user": {
                      "$ref": "#/components/schemas/UserProfile"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid username or password.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "EMP001"
          },
          "employeeCode": {
            "type": "string",
            "example": "GC-2026-0001"
          },
          "employeeName": {
            "type": "string",
            "example": "Thomas John"
          },
          "designation": {
            "type": "string",
            "example": "Field Worker"
          },
          "department": {
            "type": "string",
            "example": "Operations"
          },
          "organization": {
            "type": "string",
            "example": "Green Care"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "thomasjohn@greencare.com"
          },
          "phoneNumber": {
            "type": "string",
            "example": "+91-9847112233"
          },
          "profilePicture": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/profile/thomasjohn.jpg"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Invalid username or password."
          }
        }
      }
    }
  }
}